                        ],
                        work: null
                    },
                    randomEvents: [
                        'Ingram is reading the same paragraph for the 10th time.',
                        'Ingram just apologized to a bookshelf.',
                        'Ingram is counting their medication. Again.',
                        'Ingram saw Rémy today. They cannot stop thinking about it.',
                        'Ingram is writing an email to their professor. Draft 7.'
                    ],
                    lines: {
                        idle: 'is curled in their corner, surrounded by books.',
                        fragile: 'is counting their pills. They are sure they took them.',
                        waiting: 'is staring at their phone. Rémy has not texted back.'
                    }
                }
            }
        };

        const phases = [
            { name: 'Morning', time: '08:00-12:00' },
            { name: 'Afternoon', time: '12:00-16:00' },
            { name: 'Evening', time: '16:00-20:00' },
            { name: 'Night', time: '20:00-00:00' }
        ];

        function showCharSelect() {
            document.getElementById('titleScreen').style.display = 'none';
            document.getElementById('charSelect').style.display = 'flex';
        }

        function startGame(char) {
            game.current = char;
            document.getElementById('charSelect').style.display = 'none';
            document.getElementById('gameUI').style.display = 'flex';
            initUI();
        }

        function initUI() {
            updateUI();
            renderActions();
            updatePartyBar();
            addStory(`You check in on ${game.chars[game.current].name}.`);
        }

        function isCharAvailable(charId) {
            const c = game.chars[charId];
            if (charId === game.current) return true;
            if (c.workPhases.includes(game.phase)) return false;
            return true;
        }

        function isAtWork(charId) {
            const c = game.chars[charId];
            return c.workPhases.includes(game.phase);
        }

        function updateUI() {
            const c = game.chars[game.current];
            
            document.getElementById('charPanel').className = `char-panel ${c.theme}`;
            document.getElementById('bigPortrait').textContent = c.emoji;
            document.getElementById('charName').textContent = c.name;
            document.getElementById('charSub').textContent = c.sub;
            
            const atWork = isAtWork(game.current);
            document.getElementById('locationTag').textContent = atWork ? `${c.name} (at work)` : c.location;
            document.getElementById('sceneVisual').textContent = atWork ? '🏢' : c.sceneEmoji;
            
            let mood = c.lines.idle;
            if (c.hunger < 30) mood = c.lines.hungry || mood;
            else if (c.attention < 30) mood = c.lines.needy || mood;
            else if ((c.chaos > 80) || (c.cruelty > 80)) mood = c.lines.chaotic || c.lines.cruel || mood;
            
            document.getElementById('sceneText').textContent = `${c.name} ${mood}`;
            
            document.getElementById('phaseName').textContent = phases[game.phase].name;
            document.getElementById('phaseTime').textContent = phases[game.phase].time;
            document.getElementById('apCurrent').textContent = game.ap;
            document.getElementById('moneyDisplay').textContent = `$${c.money}`;
            
            updateBar('hunger', c.hunger);
            updateBar('attention', c.attention);
            updateBar('energy', c.energy);
            
            document.getElementById('special1Label').textContent = c.special1;
            document.getElementById('special2Label').textContent = c.special2;
            document.getElementById('special1Bar').style.width = (c[c.special1.toLowerCase()] || 50) + '%';
            document.getElementById('special2Bar').style.width = (c[c.special2.toLowerCase()] || 50) + '%';
            
            const btn = document.getElementById('nextBtn');
            btn.disabled = game.ap > 0;
            btn.className = game.ap === 0 ? 'next-phase-btn active' : 'next-phase-btn';
            btn.textContent = game.ap === 0 ? 'Next Phase →' : `${game.ap} hours left`;
        }

        function updateBar(type, val) {
            const bar = document.getElementById(type + 'Bar');
            bar.style.width = val + '%';
            bar.className = 'need-bar-fill ' + (val < 30 ? 'bar-low' : val < 60 ? 'bar-mid' : 'bar-high');
        }

        function updatePartyBar() {
            Object.keys(game.chars).forEach(k => {
                const pm = document.getElementById(`pm-${k}`);
                const st = document.getElementById(`status-${k}`);
                const ch = game.chars[k];
                const available = isCharAvailable(k);
                const isCurrent = k === game.current;
                
                pm.classList.remove('active', 'inactive', 'locked');
                
                if (isCurrent) {
                    pm.classList.add('active');
                    pm.style.opacity = '1';
                    pm.style.cursor = 'default';
                } else if (!available) {
                    pm.classList.add('locked');
                    pm.style.opacity = '0.3';
                    pm.style.cursor = 'not-allowed';
                } else if (game.actionTaken) {
                    pm.classList.add('inactive');
                    pm.style.opacity = '0.4';
                    pm.style.cursor = 'not-allowed';
                } else {
                    pm.classList.add('inactive');
                    pm.style.opacity = '0.7';
                    pm.style.cursor = 'pointer';
                }
                
                let status = 'ok', icon = '✓';
                if (ch.hunger < 30 || ch.energy < 20) { status = 'bad'; icon = '✗'; }
                else if (ch.attention < 40 || ch.sanity < 40) { status = 'mid'; icon = '!'; }
                
                st.className = `member-status status-${status}`;
                st.textContent = icon;
            });
        }

        function renderActions() {
            const grid = document.getElementById('actionGrid');
            const c = game.chars[game.current];
            const atWork = isAtWork(game.current);
            const actionList = atWork && c.actions.work ? c.actions.work : c.actions.default;
            
            grid.innerHTML = '';
            
            actionList.forEach((a, i) => {
                const btn = document.createElement('button');
                btn.className = 'action-btn' + (a.used ? ' used' : '');
                btn.innerHTML = `
                    <span class="btn-emoji">${a.emoji}</span>
                    <span class="btn-name">${a.name}</span>
                    <span class="btn-cost">${a.cost}h</span>
                `;
                btn.disabled = a.used || game.ap < a.cost;
                btn.onclick = () => doAction(i, atWork);
                grid.appendChild(btn);
            });
        }

        function doAction(index, isWork) {
            const c = game.chars[game.current];
            const actionList = isWork && c.actions.work ? c.actions.work : c.actions.default;
            const a = actionList[index];
            
            if (a.used || game.ap < a.cost) return;
            
            game.ap -= a.cost;
            a.used = true;
            game.actionTaken = true;
            
            if (a.name.includes('Eat')) c.hunger = Math.min(100, c.hunger + 25);
            if (a.name.includes('Text')) c.attention = Math.min(100, c.attention + 20);
            if (a.name.includes('Gym') || a.name.includes('Study')) c.energy = Math.max(0, c.energy - 15);
            if (a.name.includes('Meds')) { c.sanity = Math.min(100, c.sanity + 20); c.energy += 10; }
            
            if (a.unique) {
                if (c.chaos !== undefined) c.chaos += 10;
                if (c.control !== undefined) c.control += 10;
                if (c.cruelty !== undefined) c.cruelty += 10;
                if (c.sanity !== undefined) c.sanity += 15;
            }
            
            if (a.name.includes('Shop')) c.money -= 15;
            if (a.name.includes('Dining')) c.money -= 30;
            
            if (isWork && (a.name.includes('Surgery') || a.name.includes('Audit') || a.name.includes('Test'))) {
                const pay = Math.floor(Math.random() * 30) + 20;
                c.money += pay;
                addStory(`${c.name} earned $${pay} for that.`);
            }
            
            const stories = {
                'Text Mikhail': `Dottie sends 7 texts in a row. Mikhail reads them. He does not respond.`,
                'Eat Ramen': `The noodles are instant. The regret is immediate.`,
                'Smoke': `Five minutes of peace. Worth it.`,
                'Take Selfies': `47 photos. Zero keepers. Dottie posts one anyway.`,
                'Online Shop': `Dottie bought something they do not remember adding to cart. $15 gone.`,
                'Start Drama': `The group chat is on fire. Dottie is thriving.`,
                'Check Schedule': `Mikhail confirms: everything is on track. He allows himself to breathe.`,
                'Go to Gym': `5 AM. Exactly on time. The routine holds.`,
                'Pour Wine': `Rémy swirls the glass. It is too early. He does not care.`,
                'Text Ingram': `Rémy sends "hey." Ingram will stare at this for twenty minutes.`,
                'Take Meds': `Ingram counts the pills twice. Then once more. Then takes them.`,
                'Surgery': `Rémy saves a life. He feels nothing.`,
                'Security Audit': `Mikhail finds three vulnerabilities. He is satisfied.`
            };
            
            addStory(stories[a.name] || `${c.name} ${a.name.toLowerCase()}.`);
            
            if (Math.random() < 0.3) randomEvent();
            
            updateUI();
            renderActions();
            updatePartyBar();
        }

        function randomEvent() {
            const c = game.chars[game.current];
            const events = c.randomEvents || ['Something happened.'];
            const text = events[Math.floor(Math.random() * events.length)];
            addStory(text);
        }

        function switchChar(char) {
            if (game.actionTaken) {
                addStory(`${game.chars[game.current].name} is busy. You cannot switch now.`);
                return;
            }
            if (!isCharAvailable(char)) {
                const c = game.chars[char];
                const working = c.workPhases.includes(game.phase);
                addStory(`${c.name} is at work (${working ? phases[game.phase].name : ''}). You cannot reach them.`);
                return;
            }
            if (char === game.current) return;
            
            game.current = char;
            const newChar = game.chars[char];
            
            Object.values(game.chars).forEach(c => {
                if (c.actions.default) c.actions.default.forEach(a => a.used = false);
                if (c.actions.work) c.actions.work.forEach(a => a.used = false);
            });
            
            addStory(`You check on ${newChar.name} instead.`);
            updateUI();
            renderActions();
            updatePartyBar();
        }

        function nextPhase() {
            if (game.ap > 0) return;
            
            const next = (game.phase + 1) % 4;
            const overlay = document.getElementById('fadeOverlay');
            const title = document.getElementById('fadeTitle');
            const stories = document.getElementById('fadeStories');
            
            title.textContent = `${phases[game.phase].name} → ${phases[next].name}`;
            
            const vigs = [
                `💗 Dottie ${game.chars.dottie.energy < 30 ? 'crashed' : 'caused problems'}.`,
                `🛡️ Mikhail ${game.chars.mikhail.guilt > 60 ? 'felt guilty about nothing' : 'maintained control'}.`,
                `🍷 Rémy ${game.chars.remy.cruelty > 70 ? 'hurt someones feelings' : 'charmed a waiter'}.`,
                `📚 Ingram ${game.chars.ingram.sanity < 50 ? 'slipped a little' : 'held it together'}.`
            ];
            stories.innerHTML = vigs.map(v => `<div>${v}</div>`).join('');
            
            overlay.classList.add('active');
            
            setTimeout(() => {
                game.phase = next;
                
                if (game.phase === 0) {
                    game.day++;
                    Object.values(game.chars).forEach(c => {
                        if (c.dailyIncome) {
                            const gain = Math.floor(Math.random() * (c.dailyIncome.max - c.dailyIncome.min)) + c.dailyIncome.min;
                            c.money += gain;
                        }
                    });
                }
                
                game.ap = 4;
                game.actionTaken = false;
                
                Object.values(game.chars).forEach(c => {
                    if (c.actions.default) c.actions.default.forEach(a => a.used = false);
                    if (c.actions.work) c.actions.work.forEach(a => a.used = false);
                });
                
                if (!isCharAvailable(game.current)) {
                    const forcedOut = game.chars[game.current];
                    const available = Object.keys(game.chars).find(k => isCharAvailable(k));
                    if (available) {
                        addStory(`${forcedOut.name} had to leave for work.`);
                        game.current = available;
                    }
                }
                
                overlay.classList.remove('active');
                updateUI();
                renderActions();
                updatePartyBar();
                addStory(`${phases[game.phase].name} begins.`, true);
            }, 2000);
        }

        function addStory(text, isTime = false) {
            const log = document.getElementById('storyLog');
            const entry = document.createElement('div');
            entry.className = isTime ? 'story-entry time' : 'story-entry';
            
            const hour = 8 + (game.phase * 4) + (4 - game.ap);
            entry.textContent = isTime ? text : `[${hour.toString().padStart(2, '0')}:00] ${text}`;
            
            log.appendChild(entry);
            log.scrollTop = log.scrollHeight;
        }
    </script>
