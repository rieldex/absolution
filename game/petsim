                    dailyIncome: { min: 10, max: 20, source: 'stipend' },
                    workPhases: [],
                    pronoun: 'they', possessive: 'their', reflexive: 'themself',
                    emoji: '📚', theme: 'ingram-theme',
                    location: "Ingram's Corner", sceneEmoji: '📖',
                    special1: 'Sanity', special2: 'Submission',
                    hunger: 40, attention: 30, energy: 25,
                    sanity: 60, submission: 75,
                    status: 'ok',
                    actions: {
                        default: [
                            { emoji: '💊', name: 'Take Meds', cost: 1, used: false, unique: true },
                            { emoji: '📖', name: 'Study', cost: 2, used: false },
